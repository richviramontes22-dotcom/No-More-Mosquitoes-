# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Supabase (public — safe for client) ──────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Supabase (secret — server only, NEVER expose to browser) ─────────────────
# Required for: admin employee invite (auth.admin.inviteUserByEmail)
# Get from: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Regrid (property GIS lookup) ─────────────────────────────────────────────
REGRID_API_KEY=...

# ─── App base URL (used for Stripe + Supabase redirect URLs) ──────────────────
# Set to your production domain in Netlify env vars
# Example: https://nomoremosquitoes.us
APP_BASE_URL=https://nomoremosquitoes.us

# ─── Crisp Chat ───────────────────────────────────────────────────────────────
VITE_CRISP_WEBSITE_ID=...
