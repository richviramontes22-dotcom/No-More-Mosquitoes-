# ─── Resend (transactional email) ─────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# The From address shown on all outbound emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=No More Mosquitoes <hello@nomoremosquitoes.us>

# ─── Reminder automation (Netlify scheduled function) ─────────────────────────
# Set to "true" in development/staging to log what would be sent WITHOUT calling Resend.
# In production this must be "false" (or unset) so real reminder emails are delivered.
# Safe default: false
REMINDER_DRY_RUN=false

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Enable automatic Stripe Tax on all charges (requires Stripe Tax activated in Dashboard).
# Set to "true" in production once Stripe Tax is configured; leave "false" during testing.
STRIPE_AUTO_TAX=false

# ─── Supabase (public — safe for client) ──────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Supabase (secret — server only, NEVER expose to browser) ─────────────────
# Required for: admin employee invite (auth.admin.inviteUserByEmail)
# Get from: Supabase Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Parcel Acreage Lookup (county GIS adapters — cache-first) ────────────────
# Google Maps server key (backend geocoding — never expose to browser)
GOOGLE_MAPS_SERVER_KEY=

# Google Maps browser key (frontend Places Autocomplete — restrict by domain in GCP)
VITE_GOOGLE_MAPS_BROWSER_KEY=

# Set false to disable DB caching (not recommended in production)
PARCEL_CACHE_ENABLED=true

# Redis hot cache (optional — leave blank to use DB only)
REDIS_URL=
PARCEL_REDIS_CACHE_ENABLED=false

# Per-request timeouts (milliseconds)
PARCEL_LOOKUP_TIMEOUT_MS=8000
COUNTY_ADAPTER_TIMEOUT_MS=8000

# Rate limiting
PARCEL_RATE_LIMIT_ANON_PER_HOUR=20
PARCEL_RATE_LIMIT_AUTH_PER_HOUR=100

# ─── Regrid (legacy fallback — disabled by default) ────────────────────────────
# Regrid is no longer the default acreage source.
# Enable only if county GIS + SCAG fail AND you have a CA-covering subscription.
REGRID_FALLBACK_ENABLED=false
REGRID_API_KEY=...

# ─── App base URL (used for Stripe + Supabase redirect URLs) ──────────────────
# Set to your production domain in Netlify env vars
# Example: https://nomoremosquitoes.us
APP_BASE_URL=https://nomoremosquitoes.us

# ─── Twilio (SMS notifications) ───────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
# All three must be set for SMS to be enabled. Leave blank to disable SMS (NullSmsProvider used).
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ─── Company info (used in email footers and SMS help responses) ───────────────
# Full company mailing address shown in every email footer
COMPANY_ADDRESS=123 Main St, City, State ZIP
# Support email shown in transactional emails
SUPPORT_EMAIL=support@nomoremosquitoes.us
# Support phone number shown in SMS help responses
SUPPORT_PHONE=(555) 555-5555

# ─── Owner / Admin Alert Recipients ───────────────────────────────────────────
# Primary recipient for all admin alert emails (payment failures, new leads, etc.)
OWNER_EMAIL=owner@nomoremosquitoes.us
# Optional: owner mobile for SMS alerts on warning/critical events
OWNER_PHONE=+15555550000
# Comma-separated fallback list if OWNER_EMAIL is not set
ADMIN_ALERT_EMAILS=admin@nnm.com,richard@nomoremosquitoes.us

# ─── Crisp Chat ───────────────────────────────────────────────────────────────
VITE_CRISP_WEBSITE_ID=...
